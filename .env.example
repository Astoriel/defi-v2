# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/defi_v2

# [TESTING / PORTFOLIO MODE]
# Set to 'true' to bypass all APIs and generate realistic SQL tables.
USE_MOCK_DATA=true

# Web3 APIs
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
COINGECKO_API_KEY=YOUR_COINGECKO_KEY

# Google Ads API (OAuth 2.0 Credentials recommended by Google)
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_DEV_TOKEN
GOOGLE_ADS_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_ADS_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_ADS_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
GOOGLE_ADS_LOGIN_CUSTOMER_ID=YOUR_CUSTOMER_ID

# Twitter / X Ads API (OAuth 1.0a)
TWITTER_CONSUMER_KEY=YOUR_TWITTER_KEY
TWITTER_CONSUMER_SECRET=YOUR_TWITTER_SECRET
TWITTER_ACCESS_TOKEN=YOUR_TWITTER_TOKEN
TWITTER_ACCESS_TOKEN_SECRET=YOUR_TWITTER_TOKEN_SECRET
TWITTER_ACCOUNT_ID=YOUR_TWITTER_ACCOUNT_ID

# Frontend Analytics Bridge (PostHog)
POSTHOG_API_KEY=YOUR_POSTHOG_KEY
POSTHOG_PROJECT_ID=YOUR_POSTHOG_PROJECT_ID
POSTHOG_HOST=https://app.posthog.com
